rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Returns true if the caller is a signed-in, active admin.
    // Checks both role and status so a disabled admin loses access server-side.
    // Guards against missing user doc (u == null) to fail closed, not crash.
    function isAdmin() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      return request.auth != null
        && u != null
        && u.get('role', '') == "admin"
        && u.get('status', '') == "active";
    }

    // Fields that only an admin may set on a user document.
    // A user writing their own document must not touch these.
    function writesProtectedFields() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasAny(['role', 'status']);
    }

    function isSignedIn() {
      return request.auth != null;
    }

    // ─── Rooms ───────────────────────────────────────────────────────────────
    // Public read: listings are intentionally public (room rental platform).
    // Authenticated users may create rooms they own.
    // Only the owner or an admin may update / delete.
    match /rooms/{roomId} {
      allow read: if true;

      allow create: if isSignedIn() &&
        request.auth.uid == request.resource.data.owner.id;

      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.owner.id || isAdmin()
      );

      allow delete: if isSignedIn() && (
        request.auth.uid == resource.data.owner.id || isAdmin()
      );
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    // Users can read and write their own document.
    // Admins can read and write any user document.
    match /users/{uid} {
      allow read:   if isSignedIn() && (request.auth.uid == uid || isAdmin());
      // On create, role must be "user" (or absent) and status must be "active"
      // (or absent). Only an admin can ever set role="admin".
      allow create: if isSignedIn() && request.auth.uid == uid
        && request.resource.data.get('role', 'user') == 'user'
        && request.resource.data.get('status', 'active') == 'active';
      // Users may update their own document only when they don't touch role/status.
      // Admins may update any field on any user document.
      allow update: if isSignedIn() && (
        (request.auth.uid == uid && !writesProtectedFields()) || isAdmin()
      );
      allow delete: if isAdmin();
    }

    // ─── Admin incoming notifications ─────────────────────────────────────
    // Signed-in users may only create events of known system kinds and must
    // supply the required fields. This prevents spam / arbitrary writes while
    // still allowing client-side registration and listing events.
    // Only admins may read, update, or delete.
    match /admin_notifications/{notifId} {
      allow create: if isSignedIn()
        && request.resource.data.kind in [
             'user-registered', 'listing-posted',
             'listing-pending', 'listing-flagged'
           ]
        && request.resource.data.keys().hasAll(['kind', 'title', 'body', 'createdAt', 'read'])
        && request.resource.data.read == false;
      allow read, update, delete: if isAdmin();
    }

    // ─── Outbound notification templates ──────────────────────────────────
    // Only admins may manage templates.
    match /notification_templates/{templateId} {
      allow read, write: if isAdmin();
    }

    // ─── Outbound notification campaigns ──────────────────────────────────
    // Any signed-in user may read campaigns (needed for the notification inbox).
    // Only admins may create, update, or delete campaigns.
    match /notification_campaigns/{campaignId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    // ─── OTP codes & password-reset tokens ────────────────────────────────
    // These are written and read exclusively by Cloud Functions (Admin SDK
    // bypasses rules). Clients must never access them directly.
    match /otp_codes/{phone} {
      allow read, write: if false;
    }

    match /password_reset_tokens/{phone} {
      allow read, write: if false;
    }
  }
}
